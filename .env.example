# ── WormCup Config ──────────────────────────────────────────────
# Copy ke .env terus edit: cp .env.example .env

# API endpoint (default: https://api.worm.wtf)
# WORMCUP_API=https://api.worm.wtf

# Delay antar tap dalam detik (default: 15)
# Naikin kalau kena 429 terus
# WORMCUP_DELAY=15

# Max match prediction per akun (default: 3)
# Set 0 buat skip predict
# WORMCUP_PREDICT=3

# Path ke token.txt (default: ./token.txt)
# WORMCUP_TOKENS=./token.txt

# Path ke proxy.txt (default: ./proxy.txt)
# WORMCUP_PROXY=./proxy.txt

# Spread strategy: tiap akun prediksi skor BEDA (default: true)
# false = semua akun prediksi skor sama
# WORMCUP_SPREAD=true

# Loop interval dalam detik (default: 0 = sekali jalan)
# WORMCUP_LOOP=600
